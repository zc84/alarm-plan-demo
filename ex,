  const [comment, setComment] = useState('')

  return (
    <section>
      <h2>Approval Center</h2>
      <p className="lead">
        Hierarchical release process with comments, reminders, deadline awareness, rejection handling, and restart
        behavior for impacted participants.
      </p>

      <div className="grid two">
        {approvals.map((item) => {
          const plan = alarmPlans.find((candidate) => candidate.id === item.planId)
          return (
            <article key={item.id} className="panel">
              <h3>{plan?.title ?? item.planId}</h3>
              <p>Current step: {item.currentStep}</p>
              <p>Pending with: {item.pendingWithRole}</p>
              <p>Deadline: {item.deadline}</p>
              <p>
                Changed fields: <em>{plan?.changedFields.join(', ')}</em>
              </p>

              <label>
                Comment / Justification
                <textarea
                  value={comment}
                  onChange={(event) => setComment(event.target.value)}
                  placeholder="Add approval note or rejection explanation"
                />
              </label>

              <div className="actions">
                <button type="button" className="btn" onClick={() => approveRequest(item.id, comment)}>
                  Confirm
                </button>
                <button type="button" className="btn danger" onClick={() => rejectRequest(item.id, comment)}>
                  Reject (restart)
                </button>
              </div>

              <h4>Thread</h4>
              <ul>
                {item.comments.map((entry) => (
                  <li key={`${entry.author}-${entry.createdAt}`}>
                    <strong>{entry.author}</strong>: {entry.message}
                  </li>
                ))}
              </ul>
            </article>
          )
        })}
      </div>
    </section>
  )
}
